{
  "compilerOptions": {
    "target": "ES2018",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@/*": [
        "./*"
      ],
      "@firebase/*": [
        "./app/src/firebase/*"
      ],
      "@components/*": [
        "./app/components/*"
      ],
      "@ai/*": [
        "./app/src/ai/*"
      ],
      "@github/*": [
        "./app/src/github/*"
      ],
      "@hooks/*": [
        "./app/hooks/*"
      ],
      "@api/*": [
        "./app/api/*"
      ],
      "@types/*": [
        "./app/types/*"
      ]
    },
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "noEmit": true,
    "incremental": true,
    "module": "esnext",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "plugins": [
      {
        "name": "next"
      }
    ]
  },
  "include": [
    "next-env.d.ts",
    ".next/types/**/*.ts",
    "**/*.ts",
    "**/*.tsx",
    ".next/dev/types/**/*.ts"
  ],
  "exclude": [
    "node_modules"
  ]
}
